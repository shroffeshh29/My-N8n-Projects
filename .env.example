# Environment variables template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub.

# Your Groq API Key (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Your deployed n8n webhook URL
# Example: https://your-n8n-instance.up.railway.app/webhook/generate-test-cases
N8N_WEBHOOK_URL=http://localhost:5678/webhook/generate-test-cases

# Slack Incoming Webhook URL (optional - for notifications)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
